# --- Secrets & credentials — NEVER commit these ---
# API keys live in backend/data/secrets.json; auth tokens in token_cache.bin.
# These patterns cover them wherever they land, plus common secret files.
data/
**/data/
secrets.json
**/secrets.json
token_cache.bin
**/token_cache.bin
*.key
*.pem
.env
.env.*
!.env.example
.mcp.json

# --- Python ---
venv/
.venv/
__pycache__/
*.pyc

# --- Frontend build artifacts ---
frontend/node_modules/
frontend/dist/
frontend/.angular/

# --- Editors ---
.vscode/
.idea/
